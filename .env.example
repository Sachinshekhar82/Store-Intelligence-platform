# General Settings
ENVIRONMENT=development
LOG_LEVEL=info

# Database Configuration
# Use "db" instead of "localhost" when running within Docker Compose
DATABASE_URL=postgresql://postgres:password123@localhost:5432/store_intelligence

# Redis Configuration
# Use "redis" instead of "localhost" when running within Docker Compose
REDIS_URL=redis://localhost:6379/0

# Re-ID Configuration
REID_MATCH_THRESHOLD=0.85
REID_WINDOW_HOURS=4
